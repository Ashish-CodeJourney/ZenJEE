# ============================================================
# ZenJEE — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Gemini API (Google Generative AI)
# Get your key at: https://aistudio.google.com/app/apikey
# This MUST remain server-side only — never expose in client.
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# App configuration
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=ZenJEE
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Encryption — used to encrypt journal entries in localStorage
# Generate a secure random 32-char string for production.
# ------------------------------------------------------------
NEXT_PUBLIC_STORAGE_VERSION=1
